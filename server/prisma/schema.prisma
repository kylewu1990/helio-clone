// 内部自用,SQLite 零配置起步。要上 Postgres:把 provider 改成 "postgresql",
// DATABASE_URL 换成 pg 连接串,再 prisma db push 即可。
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(cuid())
  handle       String          @unique
  name         String
  avatarColor  Int             @default(1) // 对应 --identity-1..12
  status       String?
  isAssistant  Boolean         @default(false) // AI 助手
  autoRespond  Boolean         @default(true) // 助手:频道里无需 @ 也主动参与相关讨论
  systemPrompt String? // 助手人设/指令
  memory       String? // 助手长期记忆(L2,跨频道,注入 system prompt;UI 可编辑 + remember 工具自更新)
  provider     String? // 供应商标识:server=用服务器配置,或 openai/deepseek/custom 等
  baseUrl      String? // 助手自带:OpenAI 兼容 baseURL(选「服务器共享」时留空)
  apiKey       String? // 助手自带:密钥(内部自用,明文存库)
  model        String? // 模型名
  skills       String? // 启用的技能 id,JSON 数组字符串
  createdById  String? // 创建该助手的用户
  createdAt    DateTime        @default(now())
  messages      Message[]
  memberships   ChannelMember[]
  cursors       ReadCursor[]
  reactions     Reaction[]
  mentions      Mention[]
  tasksAssigned Task[]          @relation("TaskAssignee")
  tasksCreated  Task[]          @relation("TaskCreator")
  ownedChannels Channel[]       @relation("ChannelOwner") // v3 G1
  memories      Memory[]        @relation("AgentMemory")  // v3 G3:本 AI 的所有记忆条目
}

// v3 Phase A:Channel 项目化(G1)。
// 频道从"聊天容器"升格为"项目实体":有 kind / goal / scope / phase / owner / 时间窗。
// 向后兼容:既有频道 kind=null 视为 'discussion',不破坏。
model Channel {
  id         String          @id @default(cuid())
  name       String
  topic      String?
  isDM       Boolean         @default(false)
  isPrivate  Boolean         @default(false)
  archivedAt DateTime?
  // v3 G1 项目语义字段(全部可选 → SQLite alter 不丢数据)
  kind       String?         // 'project' | 'discussion' | 'dm' | 'random' | null(老数据 → discussion)
  goal       String?         // 项目目标(<=200 chars)— kind=project 时必填(server 端校验)
  scope      String?         // 项目范围(可选)
  phase      String?         // 'discovery' | 'build' | 'review' | 'ship' | 'maintenance'
  ownerId    String?         // 项目负责人 User.id
  startedAt  DateTime?       // 项目开始时间(创建即 set)
  deadline   DateTime?       // 项目截止
  createdAt  DateTime        @default(now())
  messages  Message[]
  members   ChannelMember[]
  cursors   ReadCursor[]
  mentions  Mention[]
  tasks     Task[]
  events    Event[]
  owner     User?           @relation("ChannelOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  memories  Memory[]        @relation("ChannelMemories") // G3
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  joinedAt  DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model Message {
  id        String     @id @default(cuid())
  channelId String
  authorId  String
  body      String
  parentId  String? // 话题串:指向父消息
  editedAt  DateTime? // 编辑过则有值
  deletedAt DateTime? // 软删除
  pinnedAt  DateTime? // 固定到频道
  toolsUsed String? // 助手回复用到的技能 id,JSON 数组
  cededBy   String? // 主动响应里「已读但未回」的助手名,JSON 数组(cede 透明)
  eventId   String? // 这条消息是某事件的「日历卡片」(同时是该事件讨论线程的根)
  // Channel-First 协作工作流(2026-05-26):AI 把执行过程/交付物直接发进频道时间线。
  // v2 Graph Paradigm:type 扩展 'a2a_response'(A2A 回应)和 'optimizer_suggestion'(Optimizer 主动建议卡)。
  type      String? // null=普通消息 | progress_card | delivery_card | a2a_response | optimizer_suggestion
  cardJson  String? // 卡片结构化数据(进度阶段 / 交付入口·diff·验证·下一步 / Optimizer 建议主体),随 RunEvent / 任务完成更新
  whyJson   String? // v2 Why 注释:可解释性 — 为什么这条消息是这样(intent 命中关键词等)
  createdAt DateTime   @default(now())
  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Message?   @relation("Thread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Message[]  @relation("Thread")
  event     Event?     @relation("EventCard", fields: [eventId], references: [id], onDelete: SetNull)
  reactions Reaction[]
  mentions  Mention[]

  @@index([channelId, createdAt])
  @@index([parentId])
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model ReadCursor {
  id                String   @id @default(cuid())
  channelId         String
  userId            String
  lastReadMessageId String?
  updatedAt         DateTime @updatedAt
  channel           Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model Mention {
  id        String    @id @default(cuid())
  messageId String
  userId    String // 被提及者
  channelId String
  createdAt DateTime  @default(now())
  readAt    DateTime?
  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  status      String   @default("todo") // todo | doing | review | done(兼容旧值;新枚举见 Mission 工作流)
  channelId   String?
  assigneeId  String?
  createdById String?
  sortOrder   Int      @default(0)
  // AI Workforce 工作流扩展(全部可选,db push 增量不丢数据)
  missionId      String? // 归属 Mission
  priority       String? // urgent | high | medium | low
  expectedOutput String? // 预计交付物
  reviewerId     String? // 指定审查者(标量,不建关系,代码侧解析)
  // v2 Graph Paradigm:递归任务图(子任务挂父任务)+ 可解释性。
  // v3 欠债清理:autonomyLevel 字段删除(0 写入,API 实时算更可靠;详见 /api/channels/:id/graph 的 autonomyFor)。
  parentTaskId   String? // 父任务 id(E7 递归展开;v2 不强制写)
  whyJson        String? // 为什么这样拆分 / 派给这个 AI / 选这个优先级
  // Phase T:任务类型(替代魔法前缀 title.startsWith('做 PPT:'))。null=普通任务 | 'deck'
  kind        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  channel     Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator     User?    @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status, sortOrder])
  @@index([missionId])
  @@index([parentTaskId])
}

// ===== AI Workforce 工作流内核(2026-05-25 完整版交付新增) =====
// 设计:外键用标量字段(不建 Prisma 关系),避免改动既有 User/Channel 关系;
// 名称等展示信息由前端用已加载的 users 列表解析。全部为新表,db push 增量安全。

// Mission / Goal:用户输入目标后创建的工作单元,统领任务拆解→审查→交付→审批。
model Mission {
  id            String   @id @default(cuid())
  title         String
  goal          String // 目标原文
  status        String   @default("draft") // draft | planning | ready | running | review | delivered | archived
  runMode       String?  // auto(一键跑完) | confirm(逐步确认) | plan(只生成计划);null=未指定(等价 plan)
  templateId    String?  // 来源快速模板 id(若由模板创建)
  createdById   String? // 创建者(标量)
  contextDocIds String? // 绑定的上下文文档 id,JSON 数组字符串
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, updatedAt])
}

// AppSetting:全局应用设置(单例,id="app")。控制快速任务/通用任务的默认执行 AI 与一键执行行为。
// 内部自用,单例足够。密钥不在此存(仍随助手存),前端只读展示助手解析出的模型/端点。
model AppSetting {
  id                String   @id @default("app")
  defaultExecutorId String? // 默认执行助手(AI)id;模板/通用任务优先用它(能力不足时仍按角色路由)
  autoRun           Boolean  @default(false) // 模板默认是否「一键跑完」
  assumeDefaults    Boolean  @default(true) // 遇到澄清时是否用 MVP 默认假设继续(而不是停下等用户)
  // Phase T:编排式多 AI deck 生成开关。开=plan→fan-out→critic 多角色;关=回退单 AI。
  deckOrchestration Boolean  @default(true)
  // Phase U / R3:总编排引擎(可逆 feature flag)。'legacy'=手写 runDeckJob 状态机;
  // 'mastra'=Mastra workflow 接管控制流(等价替换)。默认 legacy,全程灰度。
  orchestrationEngine String @default("legacy")
  // Phase U / M2:visual 角色执行器细分 flag(仅 orchestrationEngine='mastra' 时生效)。
  // 'mastra-inline'=composeStep 直调 generateReply(M1 行为);'pi'=pi-agent-core runner
  // 在 scratch 目录用工具生成(M2 行为)。默认 mastra-inline,可回退。
  visualRunner       String @default("mastra-inline")
  updatedAt         DateTime @updatedAt
}

// Phase T:编排式 deck 生成的一等公民。承载首次参数(specJson)、版本链(prevJobId)、
// 角色与模型(rolesJson),取代魔法前缀(task.title)与伪 taskRunId('ppt-ai:<uuid>')。
// 标量外键(与 TaskRun/SandboxRun 同风格,不建 Prisma 关系)。
model GenerationJob {
  id                 String   @id @default(cuid())
  kind               String   @default("deck") // 'deck'(预留未来扩展)
  status             String   @default("queued") // queued|planning|drafting|composing|reviewing|ready|failed
  channelId          String?
  taskId             String? // 关联真实 Task(kind='deck')
  ownerId            String? // orchestrator AI(= 频道 owner / task assignee)
  requesterId        String? // 触发的真人
  title              String
  specJson           String? // 首次参数:topic/audience/deckType/pageCount/themeId/skillIds/attachments
  rolesJson          String? // plan 产出的角色集 + 每角色 model/状态(供编排卡 & 审计)
  prevJobId          String? // revision 链(沿链取上版 HTML)
  resultSandboxRunId String? // 本轮产物落在哪个 SandboxRun
  snapshotJson       String? // Phase U:Mastra workflow run snapshot(suspend/resume 锚点,预留)
  error              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([channelId, status])
  @@index([taskId])
}

// PendingInput:AI 缺信息 / 需澄清时创建的「结构化用户动作」。
// 不再只在聊天里丢抽象问题:说明为什么问、给推荐默认、给「按 MVP 默认假设继续」、给自定义输入。
// 状态机:pending →(用户选择)→ resolved | skipped(skip=用默认假设继续)。
model PendingInput {
  id            String    @id @default(cuid())
  runId         String? // 关联 TaskRun(执行后检测到缺信息时)
  taskId        String?
  missionId     String?
  assistantId   String? // 提问的执行助手
  field         String?   @default("info") // 字段标识(如 city / scope / info)
  question      String // 给用户看的问题(人话)
  reason        String? // 为什么需要问
  optionsJson   String? // 候选项 JSON: [{label, value, hint}]
  recommended   Int? // 推荐默认项下标(指向 options)
  defaultValue  String? // 「按 MVP 默认假设继续」时采用的值
  allowCustom   Boolean   @default(true) // 是否允许自定义输入
  status        String    @default("pending") // pending | resolved | skipped
  answer        String? // 用户最终采用的值(自定义或选项或默认)
  resolvedById  String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([status, createdAt])
  @@index([taskId, createdAt])
  @@index([missionId, createdAt])
}

// Review:质量审查结论,可挂在 task 或 mission 上。
model Review {
  id         String   @id @default(cuid())
  missionId  String?
  taskId     String?
  reviewerId String? // 审查者(标量)
  verdict    String // pass | needs_fix | blocked
  checksJson String? // 检查清单 JSON: [{label, ok}]
  notes      String?
  createdAt  DateTime @default(now())

  @@index([taskId, createdAt])
  @@index([missionId, createdAt])
}

// Delivery:交付物。done 任务可生成交付,经人工 approve/reject。
// v2:whyJson 记录"为什么这是合格交付"(测试通过 / browser 验证 / 改动摘要等的推理)。
model Delivery {
  id           String    @id @default(cuid())
  missionId    String?
  taskId       String?
  title        String
  summary      String?
  artifactJson String? // 交付物 JSON(文件/链接/消息引用)
  testResult   String? // pass | fail | skipped
  riskLevel    String? // low | medium | high
  status       String    @default("pending") // pending | approved | rejected
  approvedById String? // 审批人(标量)
  approvedAt   DateTime?
  createdById  String?
  whyJson      String?   // v2 可解释性
  createdAt    DateTime  @default(now())

  @@index([status, createdAt])
  @@index([missionId, createdAt])
}

// TaskRun:任务执行运行时记录。一次「开始执行」= 一行,记录执行生命周期、
// 执行者(助手)、产生的对话、用到的工具、最终输出/错误。可观察 + 可审计的核心。
// 设计:标量外键(不建关系),状态机 queued → running →(needs_approval)→ succeeded|failed|cancelled。
model TaskRun {
  id            String    @id @default(cuid())
  taskId        String // 被执行的任务
  missionId     String? // 归属 Mission(冗余,便于按 Mission 过滤)
  assistantId   String? // 执行者(AI 助手)
  channelId     String? // 执行对话所在频道(执行人与助手的 DM)
  triggeredById String? // 触发者(真人;手动开始)
  trigger       String    @default("manual") // manual | auto | approval(批准后续跑)
  status        String    @default("queued") // queued | running | needs_approval | succeeded | failed | cancelled
  messageId     String? // 助手最终回复消息 id(关联聊天)
  toolsUsed     String? // 本次用到的工具 id,JSON 数组
  output        String? // 助手最终文本(截断)
  error         String? // 失败原因
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([taskId, createdAt])
  @@index([status])
  @@index([missionId, createdAt])
}

// ApprovalRequest:高危能力(run_command/写文件/电脑控制)的人工审批请求。
// 任务执行中助手试图调用高危能力且未获授权时创建,执行挂起为 needs_approval;
// 人工 approve 后,任务可被「续跑」并放行该能力。危险动作不静默执行。
model ApprovalRequest {
  id           String    @id @default(cuid())
  runId        String? // 关联的 TaskRun
  taskId       String?
  missionId    String?
  requestedById String? // 发起请求的助手
  capability   String // run_command | write_file | computer_control ...
  command      String? // 高危动作的具体内容(如 shell 命令),供人工审阅
  status       String    @default("pending") // pending | approved | rejected
  decidedById  String? // 审批人(真人)
  decidedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([status, createdAt])
  @@index([taskId, createdAt])
}

// ===== Sandbox Runtime(2026-05-25 沙盒执行内核新增) =====
// 设计:每次代码/命令类 TaskRun 在 .helio/sandboxes/<runId>/workspace 内隔离执行,
// 主项目不被 AI 直接改;命令/写文件/build/test 全部落库;人工批准后才 apply 到主项目。
// 标量外键(不建 Prisma 关系),db push 增量安全,与既有 TaskRun/Approval 同风格。

// SandboxRun:一次隔离执行环境。一个 TaskRun 最多对应一个 SandboxRun。
model SandboxRun {
  id            String    @id @default(cuid())
  taskRunId     String // 关联的 TaskRun
  taskId        String?
  missionId     String?
  mode          String    @default("copy") // copy | git_worktree(当前非 git repo → copy fallback)
  rootPath      String // .helio/sandboxes/<runId>
  workspacePath String // .../workspace,run_command 的 cwd
  basePath      String? // .../base,纯净快照(用于 diff 基线)
  status        String    @default("preparing") // preparing | running | testing | ready_for_review | applied | discarded | failed | cancelled
  networkPolicy String    @default("allow_public_get") // none | allow_public_get | full_with_approval
  changedFiles  String? // JSON [{path,status}] (added|modified|deleted)
  diffSummary   String? // 如 "3 files, +12 -4"
  buildResult   String? // pass | fail | partial | skipped
  appliedFiles  String? // apply 后实际写回主项目的文件 JSON 数组
  error         String?
  createdById   String? // 触发者(真人)
  appliedById   String? // 执行 apply 的真人
  // Phase T:deck 产物指回 GenerationJob(deck 不再伪造 taskRunId='ppt-ai:<uuid>')
  generationJobId String?
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([taskRunId])
  @@index([status, createdAt])
  @@index([generationJobId])
}

// SandboxLog:沙盒内每一步真实记录(命令/输出/退出码/耗时/diff/test)。
model SandboxLog {
  id           String   @id @default(cuid())
  sandboxRunId String
  seq          Int      @default(0)
  type         String // prepare | command | stdout | stderr | tool | test | diff | system | error
  command      String?
  cwd          String?
  exitCode     Int?
  durationMs   Int?
  content      String? // 截断后的内容(stdout/stderr/diff 等)
  createdAt    DateTime @default(now())

  @@index([sandboxRunId, seq])
  @@index([sandboxRunId, createdAt])
}

// SandboxArtifact:沙盒产物清单(diff / 变更文件 / build 结果 / 报告)。
model SandboxArtifact {
  id           String   @id @default(cuid())
  sandboxRunId String
  kind         String // diff | file | build_result | report | test
  path         String?
  summary      String?
  sizeBytes    Int?
  metadataJson String?
  createdAt    DateTime @default(now())

  @@index([sandboxRunId, createdAt])
}

// RunEvent:Live Run 透明化内核(2026-05-26 新增)。一次 TaskRun 执行过程的「人话事件流」:
// 阶段切换 / 工具开始 / 工具结果 / 工具失败 / 写文件 / 运行命令 / 浏览器动作 / 构建 / 生成交付。
// 与 AuditEvent(给审计 / Activity Feed)区分:RunEvent 面向「执行中实时过程展示」,毫秒级广播,
// 默认层人话可读,原始日志仍在 SandboxLog / Debug。标量外键,新表 db push 增量安全。
// v2:whyJson 可选,记录「为什么选这个 phase / tool」的推理链。
model RunEvent {
  id        String   @id @default(cuid())
  runId     String // 关联的 TaskRun
  taskId    String?
  missionId String?
  channelId String? // 执行对话所在频道(广播给频道成员)
  seq       Int      @default(0)
  callId    String? // 工具调用配对 id(tool_start / tool_result|tool_error 同一 callId);用于前端精确折叠
  phase     String? // understand | context | write | verify | deliver | await
  kind      String // stage | tool_start | tool_result | tool_error | file | command | browser | build | delivery | status
  tool      String? // 原始工具名(次级展示)
  title     String // 人话标题(如「正在写入文件」「运行 pnpm build」)
  detail    String? // 命令文本 / stdout 尾 / 文件路径 / 截断结果
  status    String? // running | ok | error
  durationMs Int?
  whyJson   String? // v2 可解释性:为什么这一步(如选 write_file 而非 spawn 的理由)
  // Phase T:编排 deck 时,各角色事件挂同一 GenerationJob,供前端按 job 分泳道(修 channelRun 单 run 塌缩)
  generationJobId String?
  role      String? // content | visual | data | critic(编排泳道用)
  createdAt DateTime @default(now())

  @@index([runId, seq])
  @@index([channelId, createdAt])
  @@index([generationJobId])
}

// ===== v2 Algorithm Graph(2026-05-26 增补,Miessler 启发) =====
// 显式边表:Heliox 把"AI 组织"具象化为一张算法图谱。
// 节点不在 Edge 表里:节点是各个领域表(Task / User-as-Agent / Delivery / Message / PendingInput / Approval / RunEvent-as-Tool),
// 前端按 fromKind+fromId / toKind+toId 拼装节点。
// verb 是有限词表(10 个),对应 Heliox 自有协作动词。whyJson 记录这条边为什么存在(可解释性)。
model Edge {
  id        String   @id @default(cuid())
  channelId String? // 边所在频道(用于按频道筛选 graph;系统级边可为 null)
  fromKind  String // task | agent | delivery | progress | a2a_response | tool | memory | approval | user | mission | optimizer
  fromId    String // 节点 id(在各自表里;agent=User.id,tool="<runId>:<toolName>")
  toKind    String
  toId      String
  verb      String // assigns | delegates | reviews | approves | supplies | feeds | depends_on | blocked_by | delivers_to | monitors
  weight    Int?    // 频次或权重(tool 边可累加)
  whyJson   String? // 这条边为什么存在(命中关键词 / 关联事件 id 等)
  createdAt DateTime @default(now())

  @@index([channelId, createdAt])
  @@index([fromKind, fromId])
  @@index([toKind, toId])
  @@index([verb])
}

// AuditEvent:append-only 审计轨迹。所有关键动作写入,Activity Feed 只读这里。
model AuditEvent {
  id          String   @id @default(cuid())
  missionId   String?
  taskId      String?
  actorId     String? // 动作发起者(标量;真人或助手)
  type        String // mission.created | task.status_changed | review.submitted | delivery.created | approval.decided | terminal.command | ai.tool_call ...
  summary     String
  payloadJson String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([missionId, createdAt])
}

// v3 G3:Memory — AI 的持久记忆(L1 用 User.systemPrompt 不进本表;L2/L3 进)。
// L2 = 项目级长期知识(per agentId × channelId 一条;append-only + 滚动窗口截断)。
// L3 = 频道情节记忆(per agentId × channelId 一条;最近事件摘要,prepend,~5k chars 上限)。
// Dream Cycle(L3 → L2 固化)留 Phase B;本轮先把存储立起来。
model Memory {
  id          String   @id @default(cuid())
  agentId     String   // User.id where isAssistant=true
  channelId   String?  // L2/L3 必填;L1 不进本表
  level       Int      // 2 = project, 3 = episodic
  content     String   // Markdown / 自由文本(L2 长期 / L3 滚动摘要)
  keywords    String?  // JSON array — 检索 / Dream Cycle 索引用
  itemCount   Int      @default(0) // L3:基于几次观察;L2:几次固化
  lastDreamAt DateTime?            // 上次 Dream Cycle 固化时间
  whyJson     String?              // 为什么形成这条记忆(可解释性)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent   User    @relation("AgentMemory", fields: [agentId], references: [id], onDelete: Cascade)
  channel Channel? @relation("ChannelMemories", fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([agentId, channelId, level])
  @@index([channelId, level])
}

// 事件驱动协作轴:每个 Event 在频道里有一张「日历卡片」消息(eventId 指向它),
// 那张卡片即该事件的讨论线程根;Cron 用 remindedAt 防重复提醒。
model Event {
  id          String    @id @default(cuid())
  title       String
  startsAt    DateTime // 开始时间
  endsAt      DateTime? // 结束时间(可选)
  location    String? // 地点
  description String? // 备注
  channelId   String // 所属频道
  createdById String? // 创建者(可能是助手)
  remindedAt  DateTime? // Cron 提醒过则有值(防重复)
  createdAt   DateTime  @default(now())
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  cards       Message[] @relation("EventCard") // 该事件的日历卡片消息(线程根)

  @@index([startsAt])
}
