{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null; tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.2",
    "@prisma/client": "^6.3.1",
    "fastify": "^5.2.1",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
